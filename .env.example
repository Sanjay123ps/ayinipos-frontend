# Copy this file to .env.local for local development (Vite loads
# .env.local automatically and it's already gitignored). For a deployed
# build, set this in your hosting provider's environment variable settings
# instead (Vercel/Netlify/Railway all have a place for this in their
# dashboard) — it needs to be set at BUILD time, not just runtime, since
# Vite bakes it into the compiled JS.

# The full base URL of your deployed backend, including /api.
# Local backend:       VITE_API_URL=http://localhost:4000/api
# Deployed on Railway:  VITE_API_URL=https://your-backend.up.railway.app/api
VITE_API_URL=http://localhost:4000/api
